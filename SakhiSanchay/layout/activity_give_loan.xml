<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".admin.GiveLoanActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Disburse New Loan"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#E53935"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        app:cardBackgroundColor="#F1F8E9"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp">

        <TextView
            android:id="@+id/tvAvailableInLoanScreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="Checking available funds..."
            android:textColor="#388E3C"
            android:textStyle="bold"
            android:textSize="16sp"/>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Borrower:"
        android:layout_marginTop="20dp"/>

    <Spinner
        android:id="@+id/spinnerLoanMembers"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@android:drawable/btn_dropdown"/>

    <EditText
        android:id="@+id/etLoanAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Loan Amount (₹)"
        android:inputType="numberDecimal"
        android:layout_marginTop="15dp" />

    <EditText
        android:id="@+id/etInterestRate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Monthly Interest Rate (%)"
        android:inputType="numberDecimal"
        android:layout_marginTop="10dp" />

    <Button
        android:id="@+id/btnSubmitLoan"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:backgroundTint="#E53935"
        android:textColor="@android:color/white"
        android:text="APPROVE &amp; DISBURSE"
        android:layout_marginTop="30dp" />

</LinearLayout>