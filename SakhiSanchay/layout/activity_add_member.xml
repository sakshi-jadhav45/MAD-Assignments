<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add New Member"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1565C0"/>

    <EditText
        android:id="@+id/etMemberName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Full Name"
        android:layout_marginTop="30dp"/>

    <EditText
        android:id="@+id/etMemberEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Email Address"
        android:inputType="textEmailAddress"
        android:layout_marginTop="10dp"/>

    <EditText
        android:id="@+id/etMemberPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Set Temporary Password"
        android:inputType="textPassword"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/btnAddMemberSubmit"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="REGISTER MEMBER"
        android:layout_marginTop="30dp"/>

</LinearLayout>